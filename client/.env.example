# Stripe — publishable key ONLY (never put sk_ secret keys in client/.env)
# Same Stripe account as server/.env STRIPE_SECRET_KEY (donations + subscriptions)
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Set to "true" to show Instagram/TikTok/Facebook social journey triggers in the builder (off by default for release)
# VITE_SHOW_SOCIAL_TRIGGERS=false

# Clerk Configuration
# Get your publishable key from: https://dashboard.clerk.com/
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE
OPENAI_API_KEY=sk_test_YOUR_OPENAI_API_KEY_HERE